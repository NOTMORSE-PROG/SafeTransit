# Google Maps API Key
# Get your free API key from: https://console.cloud.google.com
# 1. Create a new project
# 2. Enable "Maps SDK for Android"
# 3. Create credentials -> API Key
# 4. Copy the key and paste it below
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Neon PostgreSQL Database
# Get your connection string from: https://console.neon.tech
# 1. Create a project at Neon
# 2. Go to Dashboard -> Connection Details
# 3. Copy the connection string (use pooled connection for serverless)
# 4. For development: Use 'dev' branch connection string
# 5. For production: Use 'main' branch connection string
# 6. Run migrations: npm run db:migrate
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Example dev branch:
# DATABASE_URL=postgresql://user:pass@ep-dev-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Example production branch:
# DATABASE_URL=postgresql://user:pass@ep-prod-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# JWT Authentication
# Generate a secure random secret key (minimum 32 characters)
# Run this command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit your actual secret to version control
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth (for Google Sign-In)
# Get your Web Client ID from: https://console.cloud.google.com
# 1. Create a new project or select existing
# 2. Go to "APIs & Services" -> "Credentials"
# 3. Click "Create Credentials" -> "OAuth 2.0 Client ID"
# 4. Application type: Select "Web application"
# 5. Name it (e.g., "SafeTransit Web Client")
# 6. Copy the CLIENT ID (ends with .apps.googleusercontent.com)
# Note: Use the WEB Client ID, not Android or iOS client IDs
# Note: Expo handles OAuth redirects automatically, no redirect URIs needed
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Backend API URL
# Deploy your backend from https://github.com/NOTMORSE-PROG/SafeTransit_Backend to Vercel
# Then paste your Vercel deployment URL here
# Example: https://safetransit-backend.vercel.app
# For local development, use: http://localhost:3000
# Required for all location search, saved places, and user features
EXPO_PUBLIC_API_URL=
